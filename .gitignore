# Local overrides (never commit)
*.local
.zshrc.local
.gitconfig.local

# macOS
.DS_Store

# Claude Code local settings
claude/settings.local.json

# This repo tracks its own Claude Code project config (.claude/ + CLAUDE.md),
# overriding ~/.gitignore_global which ignores those in every repo. Keep
# machine-local project settings out, though.
!.claude/
.claude/settings.local.json
!CLAUDE.md

# Secrets
*.token
*.key
.env*

# Codex: track only stable hand-authored config (hooks.json, herdr-agent-state.sh).
# Never the volatile/secret runtime state, even if copied into codex/ by mistake.
codex/auth.json
codex/history.jsonl
codex/config.toml
codex/*.sqlite*
codex/sessions/
codex/log/
codex/cache/

# OpenCode: only the config seed; never installed deps or auth.
config/opencode/node_modules/
config/opencode/package*.json
config/opencode/auth.json
