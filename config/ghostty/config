font-family = Dank Mono
# font-family = BlexMono Nerd Font Mono
# font-family = JetBrainsMono Nerd Font Mono
# font-family = Comic Code Ligatures   # kept for machines that have Comic Code installed
font-size = 14

# Cursor: teal #1abc9c, non-blinking (matches kitty/wezterm).
cursor-color = #1abc9c
cursor-text = #161819
cursor-style = block
cursor-style-blink = false

# Gruvbox Dark Hard: the darkest gruvbox variant (background #1d2021).
theme = Gruvbox Dark Hard

# Go one shade below gruvbox hard: override the theme's background with a
# proportionally-darkened near-black that keeps the gruvbox cool tint. This is
# the shared "darker gruvbox bg" token mirrored in herdr/nvim/kitty/etc.
background = #161819

# Treat the macOS Option key as a real Alt modifier (instead of composing
# special characters like ¡™£), so Alt-chord shortcuts reach terminal apps —
# e.g. herdr's prefix+alt+1..9 workspace jumps. Use "left" instead if you want
# to keep the right Option key for composing accented characters.
macos-option-as-alt = true

# Window background opacity. The command palette action
# "Toggle Background Opacity" switches between this value and fully opaque.
background-opacity = 0.45

# Apply opacity even when terminal apps paint explicit background cells.
# This makes opacity visible in tmux, Neovim, and similar full-screen apps.
background-opacity-cells = true

# Keep background windows sharp when multitasking.
background-blur = false

# Rounded corners, no titlebar/buttons. Keeps the window frame (needed for the
# rounded corners); the "white border" people see is actually the shadow rim,
# killed below with macos-window-shadow = false.
macos-titlebar-style = hidden
# window-decoration = none           # fully borderless but squares the corners
# macos-titlebar-style = transparent

# Drop the macOS shadow — its bright rim shows as a thin light edge on a
# borderless window.
macos-window-shadow = false

# Opacity for unfocused splits (0.0 to 1.0)
unfocused-split-opacity = 0.7

# Fill color for unfocused splits (matches the darkened gruvbox background)
unfocused-split-fill = #161819

# Divider color between splits (gruvbox bg2)
split-divider-color = #3c3836

# Scrollback buffer per terminal surface, in bytes. Default is 10 MB
# (10000000); bumped to 50 MB so long agent/build output stays scrollable.
# Byte-based, not a fixed line count. Applies to new surfaces (tabs/windows)
# created after a config reload — it does not recover already-dropped lines.
scrollback-limit = 50000000

# Clipboard: make copying land on the macOS system clipboard.
#   clipboard-write = allow lets programs running inside Ghostty (herdr, tmux,
#   Neovim) push to the system clipboard via OSC 52 without a prompt. This is
#   already Ghostty's default, but pinned here so a copy from inside a
#   multiplexer always reaches pbpaste.
#   copy-on-select = clipboard also puts mouse-selected text straight onto the
#   system clipboard (the default only copies to Ghostty's internal selection
#   buffer). Trade-off: every selection overwrites the clipboard — drop this
#   line if that clobbering is unwanted and rely on explicit Cmd-C instead.
# clipboard-read is left at its default (ask) since only copying was requested.
clipboard-write = allow
copy-on-select = clipboard
