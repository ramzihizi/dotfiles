#!/usr/bin/env bash
# narrate — read stdin text aloud with a local MLX voice, reusing Murmur's
# bundled mlx-audio runtime. The Python reader beside this wrapper loads the
# model once, chunks long prose, and feeds each generated chunk to afplay.
# Mirrors /usr/bin/say's stdin interface:
#   echo "hello there" | narrate
# Config: NARRATE_MODEL, NARRATE_VOICE, NARRATE_LANGUAGE.
set -euo pipefail

BRIDGE="$HOME/Library/Application Support/Murmur/MLXAudioBridge/com.murmur.app"
PYTHON="$BRIDGE/venv/bin/python"
# Previous Kokoro setup (kept for quick rollback):
# MODEL="prince-canuma/Kokoro-82M"
# VOICE="${NARRATE_VOICE:-am_adam}"
# Previous Qwen Base setup (voice names are not pinned without reference audio):
# MODEL="mlx-community/Qwen3-TTS-12Hz-0.6B-Base-bf16"

export NARRATE_MODEL="${NARRATE_MODEL:-mlx-community/Qwen3-TTS-12Hz-0.6B-CustomVoice-bf16}"
export NARRATE_VOICE="${NARRATE_VOICE:-Aiden}"
export NARRATE_LANGUAGE="${NARRATE_LANGUAGE:-English}"

if [[ ! -x "$PYTHON" ]]; then
  echo "narrate: Murmur runtime not found at:" >&2
  echo "  $PYTHON" >&2
  echo "narrate: open Murmur once (or reinstall) to provision its mlx-audio venv." >&2
  exit 1
fi

export HF_HOME="$BRIDGE/huggingface"

# Resolve the checked-in helper when this wrapper is invoked through its
# ~/.local/bin symlink. Bootstrap always creates a single absolute symlink.
script_path="$0"
if [[ -L "$script_path" ]]; then
  target="$(readlink "$script_path")"
  if [[ "$target" == /* ]]; then
    script_path="$target"
  else
    script_path="$(dirname "$script_path")/$target"
  fi
fi
script_dir="$(cd "$(dirname "$script_path")" && pwd)"
reader="$script_dir/narrate-reader.py"

if [[ ! -f "$reader" ]]; then
  echo "narrate: reader helper not found at $reader" >&2
  exit 1
fi

# exec keeps the Neovim job PID attached to the actual reader. Neovim signals
# it alongside afplay so pause, resume, and stop cover generation and playback.
exec "$PYTHON" "$reader"
